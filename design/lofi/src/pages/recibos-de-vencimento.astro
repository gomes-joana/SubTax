---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Recibos de vencimento" purpose="Carregar recibos de vencimento mensais">
  <div class="space-y-5">
    <div class="border border-dashed border-gray-300 rounded-lg p-8 text-center bg-white">
      <div class="w-10 h-10 bg-gray-200 rounded mx-auto mb-3"></div>
      <p class="text-sm text-gray-600 mb-1">Arrastar ficheiro ou clicar para carregar</p>
      <p class="text-xs text-gray-400">PDF, máx. 5MB</p>
    </div>

    <div class="border border-gray-300 rounded-lg bg-white overflow-hidden">
      <p class="px-4 py-3 text-xs text-gray-500 uppercase font-medium border-b border-gray-200">Recibos carregados</p>
      <div class="divide-y divide-gray-100">
        <div class="flex items-center justify-between px-4 py-3 text-sm">
          <div>
            <p class="font-medium">Janeiro 2026</p>
            <p class="text-xs text-gray-500">recibo_jan_2026.pdf</p>
          </div>
          <span class="text-gray-700">€ 1.950,00 líquido</span>
        </div>
        <div class="flex items-center justify-between px-4 py-3 text-sm">
          <div>
            <p class="font-medium">Fevereiro 2026</p>
            <p class="text-xs text-gray-500">recibo_fev_2026.pdf</p>
          </div>
          <span class="text-gray-700">€ 1.950,00 líquido</span>
        </div>
        <div class="flex items-center justify-between px-4 py-3 text-sm">
          <div>
            <p class="font-medium">Março 2026</p>
            <p class="text-xs text-gray-500">recibo_mar_2026.pdf</p>
          </div>
          <span class="text-gray-700">€ 1.950,00 líquido</span>
        </div>
        <div class="flex items-center justify-between px-4 py-3 text-sm">
          <div>
            <p class="font-medium">Abril 2026</p>
            <p class="text-xs text-gray-500">recibo_abr_2026.pdf</p>
          </div>
          <span class="text-gray-700">€ 1.950,00 líquido</span>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-between pt-2">
      <a href="/configuracao-inicial" class="text-sm text-gray-600 hover:text-gray-900">← Voltar</a>
      <a href="/configuracao-inicial" class="bg-gray-900 text-white rounded px-6 py-2 text-sm font-medium hover:bg-gray-800">Guardar</a>
    </div>
  </div>
</Layout>
