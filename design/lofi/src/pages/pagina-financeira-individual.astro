---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página financeira individual" purpose="Importar dados da página financeira individual Subvisual">
  <div class="max-w-md space-y-5">
    <div class="border border-gray-300 rounded-lg p-5 bg-white space-y-4">
      <p class="text-sm text-gray-600">Importar automaticamente os dados financeiros da tua página individual na Subvisual.</p>

      <div class="border border-dashed border-gray-300 rounded-lg p-8 text-center">
        <div class="w-10 h-10 bg-gray-200 rounded mx-auto mb-3"></div>
        <p class="text-sm text-gray-500">Colar link da página financeira</p>
        <div class="border border-gray-300 rounded px-3 py-2 mt-3 text-sm text-gray-400">https://subvisual.com/finance/ana-silva</div>
      </div>

      <a href="/pagina-financeira-individual" class="block w-full text-center border border-gray-300 rounded px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
        Importar dados
      </a>

      <div class="border-t border-gray-200 pt-4 space-y-2">
        <p class="text-xs text-gray-500 uppercase font-medium">Dados importados</p>
        <div class="flex justify-between text-sm">
          <span class="text-gray-600">Salário bruto</span>
          <span>€ 2.800,00</span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="text-gray-600">Perk balance</span>
          <span>€ 350,00/mês</span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="text-gray-600">Company balance</span>
          <span>€ 4.200,00</span>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-between pt-2">
      <a href="/configuracao-inicial" class="text-sm text-gray-600 hover:text-gray-900">← Voltar</a>
      <a href="/configuracao-inicial" class="bg-gray-900 text-white rounded px-6 py-2 text-sm font-medium hover:bg-gray-800">Guardar</a>
    </div>
  </div>
</Layout>
