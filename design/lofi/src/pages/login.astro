---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Login" purpose="Authenticate with company credentials">
  <div class="mt-16 max-w-sm mx-auto">
    <div class="border border-gray-300 rounded-lg p-8 bg-white">
      <div class="w-12 h-12 bg-gray-200 rounded mx-auto mb-6"></div>
      <p class="text-center text-lg font-medium mb-6">SubTax</p>

      <label class="block text-sm text-gray-600 mb-1">Email</label>
      <div class="border border-gray-300 rounded px-3 py-2 mb-4 text-gray-400 text-sm">ana.silva@subvisual.com</div>

      <label class="block text-sm text-gray-600 mb-1">Password</label>
      <div class="border border-gray-300 rounded px-3 py-2 mb-6 text-gray-400 text-sm">••••••••</div>

      <a href="/configuracao-inicial" class="block w-full text-center bg-gray-900 text-white rounded px-4 py-2 text-sm font-medium hover:bg-gray-800">
        Entrar
      </a>
    </div>
  </div>
</Layout>
