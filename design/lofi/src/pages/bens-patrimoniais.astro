---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bens patrimoniais" purpose="Listar bens e o seu valor atual">
  <div class="space-y-4">
    <div class="border border-gray-300 rounded-lg bg-white overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200 bg-gray-50">
            <th class="text-left px-4 py-3 font-medium text-gray-600">Bem</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Categoria</th>
            <th class="text-right px-4 py-3 font-medium text-gray-600">Valor atual</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-gray-100">
            <td class="px-4 py-3">Conta poupança</td>
            <td class="px-4 py-3 text-gray-500">Poupanças</td>
            <td class="px-4 py-3 text-right">€ 15.000,00</td>
          </tr>
          <tr class="border-b border-gray-100">
            <td class="px-4 py-3">Automóvel</td>
            <td class="px-4 py-3 text-gray-500">Veículos</td>
            <td class="px-4 py-3 text-right">€ 12.000,00</td>
          </tr>
          <tr>
            <td class="px-4 py-3">Portfólio ETF</td>
            <td class="px-4 py-3 text-gray-500">Investimentos</td>
            <td class="px-4 py-3 text-right">€ 8.500,00</td>
          </tr>
        </tbody>
      </table>
    </div>

    <a href="/bens-patrimoniais" class="inline-block border border-dashed border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-500 hover:border-gray-400 hover:text-gray-700">
      + Adicionar bem
    </a>

    <div class="flex items-center justify-between pt-2">
      <a href="/configuracao-inicial" class="text-sm text-gray-600 hover:text-gray-900">← Voltar</a>
      <a href="/configuracao-inicial" class="bg-gray-900 text-white rounded px-6 py-2 text-sm font-medium hover:bg-gray-800">Guardar</a>
    </div>
  </div>
</Layout>
