---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/tokens.css';

const { title, purpose } = Astro.props;
---

<!doctype html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} — SubTax Lo-fi</title>
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50 text-gray-900">
    <Header />
    <main class="flex-1 max-w-4xl mx-auto w-full px-6 py-10">
      <h1 class="text-3xl font-semibold mb-1">{title}</h1>
      {purpose && <p class="text-gray-600 mb-8">{purpose}</p>}
      <slot />
    </main>
    <Footer />
  </body>
</html>
